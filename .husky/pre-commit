#!/usr/bin/env sh
# Husky pre-commit hook — runs lint-staged for the frontend workspace.
# Only runs when staged files touch /app/frontend.

# If no frontend files are staged, exit fast.
STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^frontend/.*\.(js|jsx)$' || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

cd "$(git rev-parse --show-toplevel)/frontend" || exit 1
npx --no-install lint-staged
